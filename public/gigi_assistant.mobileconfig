<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>PayloadContent</key>
	<array>
		<!-- 1. Restrictions: disable Siri / dictation / server-backed Siri features (reduces Apple Siri UI / sphere) -->
		<dict>
			<key>PayloadType</key>
			<string>com.apple.applicationaccess</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>PayloadIdentifier</key>
			<string>com.apple.applicationaccess.gigi</string>
			<key>PayloadUUID</key>
			<string>11111111-1111-1111-1111-111111111111</string>
			<key>PayloadDisplayName</key>
			<string>Restrictions (Siri hardware &amp; assistant off)</string>
			<key>allowAssistant</key>
			<false/>
			<key>allowDictation</key>
			<false/>
			<key>allowAssistantWhileLocked</key>
			<false/>
			<key>allowAssistantUserGeneratedContent</key>
			<false/>
			<key>allowSpotlightInternetResults</key>
			<false/>
		</dict>

		<!--
			2. Command key mapping: routes assistant / side-button intents to GIGI Bubble (xyz.killsiri.app).
			Requires supervised / enterprise MDM that honors this payload; stock manual install may ignore unknown payload types.
		-->
		<dict>
			<key>PayloadType</key>
			<string>com.apple.command.keymapping</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>PayloadIdentifier</key>
			<string>xyz.killsiri.mdm.command.keymapping.bubble</string>
			<key>PayloadUUID</key>
			<string>55555555-5555-5555-5555-555555555555</string>
			<key>PayloadDisplayName</key>
			<string>GIGI Bubble command mapping</string>
			<key>PayloadDescription</key>
			<string>Maps hardware assistant and side-button long-press to launch GIGI in Bubble window mode.</string>
			<key>CommandMappings</key>
			<array>
				<dict>
					<key>SourceCommand</key>
					<string>com.apple.hardware.side-button.long-press.assistant</string>
					<key>Destination</key>
					<dict>
						<key>Action</key>
						<string>openApplicationBubble</string>
						<key>BundleIdentifier</key>
						<string>xyz.killsiri.app</string>
						<key>GIGIWindowMode</key>
						<string>Bubble</string>
						<key>LaunchContext</key>
						<string>MDM_ASSISTANT_HANDOFF</string>
					</dict>
				</dict>
				<dict>
					<key>SourceCommand</key>
					<string>com.apple.siri.voice-activation.hardware</string>
					<key>Destination</key>
					<dict>
						<key>Action</key>
						<string>openApplicationBubble</string>
						<key>BundleIdentifier</key>
						<string>xyz.killsiri.app</string>
						<key>GIGIWindowMode</key>
						<string>Bubble</string>
						<key>LaunchContext</key>
						<string>MDM_ASSISTANT_HANDOFF</string>
					</dict>
				</dict>
			</array>
			<key>DefaultBubbleTarget</key>
			<dict>
				<key>BundleIdentifier</key>
				<string>xyz.killsiri.app</string>
				<key>Presentation</key>
				<string>UIWindowBubbleOverlay</string>
			</dict>
		</dict>

		<!-- 3. SpringBoard: long-press side button launches GIGI (Bubble UI is shown when app activates) -->
		<dict>
			<key>PayloadType</key>
			<string>com.apple.springboard</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>PayloadIdentifier</key>
			<string>com.apple.springboard.gigi</string>
			<key>PayloadUUID</key>
			<string>22222222-2222-2222-2222-222222222222</string>
			<key>PayloadDisplayName</key>
			<string>Side button → GIGI Bubble</string>
			<key>SideButtonLongPressAction</key>
			<string>LaunchApplication</string>
			<key>SideButtonLongPressBundleIdentifier</key>
			<string>xyz.killsiri.app</string>
		</dict>

		<!-- 4. Managed WebClip for background keep-alive -->
		<dict>
			<key>PayloadType</key>
			<string>com.apple.webClip.managed</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>PayloadIdentifier</key>
			<string>com.apple.webClip.managed.gigi</string>
			<key>PayloadUUID</key>
			<string>33333333-3333-3333-3333-333333333333</string>
			<key>PayloadDisplayName</key>
			<string>GIGI Background Service</string>
			<key>Label</key>
			<string>GIGI Core</string>
			<key>URL</key>
			<string>https://killsiri.xyz/background-keepalive</string>
			<key>IsRemovable</key>
			<false/>
			<key>Precomposed</key>
			<true/>
			<key>FullScreen</key>
			<true/>
		</dict>

		<!-- 5. Root certificate (voice / TLS policy as deployed) -->
		<dict>
			<key>PayloadType</key>
			<string>com.apple.security.root</string>
			<key>PayloadVersion</key>
			<integer>1</integer>
			<key>PayloadIdentifier</key>
			<string>com.apple.security.root.gigi</string>
			<key>PayloadUUID</key>
			<string>44444444-4444-4444-4444-444444444444</string>
			<key>PayloadDisplayName</key>
			<string>GIGI Core Assistant Service Root CA</string>
			<key>PayloadCertificateFileName</key>
			<string>gigi_root.crt</string>
			<key>PayloadContent</key>
			<data>

			</data>
		</dict>
	</array>
	<key>PayloadDisplayName</key>
	<string>GIGI Core Assistant Service</string>
	<key>PayloadDescription</key>
	<string>Disables Apple Siri assistant surfaces, maps assistant hardware to GIGI Bubble (xyz.killsiri.app), remaps side button, installs root CA, and keeps background WebClip.</string>
	<key>PayloadIdentifier</key>
	<string>xyz.killsiri.mdm.assistant</string>
	<key>PayloadOrganization</key>
	<string>GIGI Engineering</string>
	<key>PayloadRemovalDisallowed</key>
	<false/>
	<key>PayloadType</key>
	<string>Configuration</string>
	<key>PayloadUUID</key>
	<string>00000000-0000-0000-0000-000000000000</string>
	<key>PayloadVersion</key>
	<integer>1</integer>
</dict>
</plist>
